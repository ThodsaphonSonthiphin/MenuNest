# MSAL (Microsoft Entra ID)
# Client ID from your App Registration in Entra ID.
VITE_MSAL_CLIENT_ID=00000000-0000-0000-0000-000000000000
# "common" accepts work, school, and personal Microsoft accounts.
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/common
# The API scope registered on the App Registration that the SPA
# should request. Example: api://<api-app-id>/access_as_user
VITE_API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user

# Google OAuth
VITE_GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Backend
VITE_API_BASE_URL=https://localhost:5001

# Syncfusion Community License key
# Register at https://www.syncfusion.com/products/communitylicense
VITE_SYNCFUSION_LICENSE_KEY=

# Application Insights (optional — set in CI from the
# APPINSIGHTS_CONNECTION_STRING repo secret).
# Leave empty for local dev — the telemetry SDK self-disables.
VITE_APPINSIGHTS_CONNECTION_STRING=

# Google Maps (build-time variables — baked into the JS bundle at `vite build`)
# Browser-restricted API key from Google Cloud Console (Maps JavaScript API enabled).
# For zero-cost prototyping use the Maps Demo Key:
#   https://mapsplatform.google.com/maps-demo-key
# Restrict production keys to HTTP referrers + Maps JavaScript API only.
# Leave blank to show the Thai-language fallback message instead of the map.
VITE_GOOGLE_MAPS_BROWSER_KEY=
# Cloud-styled Map ID — required for AdvancedMarkerElement (CF9).
# Use DEMO_MAP_ID during development; register a real Map ID in Google Cloud
# Console → Google Maps Platform → Map Management for production styling.
VITE_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
